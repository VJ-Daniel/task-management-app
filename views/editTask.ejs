<link rel="stylesheet" href="/css/main.css" />
<%- include("partials/header", { title: "Edit Task" }) %>

<div class="flex items-center justify-center min-h-[70vh]">

  <div class="card w-full max-w-md bg-base-100 shadow-xl">

    <div class="card-body">

      <h2 class="text-2xl font-bold text-center">Edit Task</h2>

      <form method="POST" action="/tasks/edit/<%= task.id %>" class="space-y-4 mt-4">

        <input 
          class="input input-bordered w-full"
          name="title" 
          value="<%= task.title %>" 
          placeholder="Title"
          required
        >

        <input 
          class="input input-bordered w-full"
          name="description" 
          value="<%= task.description %>" 
          placeholder="Description"
        >

        <input 
          class="input input-bordered w-full"
          type="date" 
          name="dueDate" 
          value="<%= task.dueDate %>"
        >

        <select class="select select-bordered w-full" name="status">
          <option value="pending" <%= task.status === "pending" ? "selected" : "" %>>
            Pending
          </option>
          <option value="complete" <%= task.status === "complete" ? "selected" : "" %>>
            Complete
          </option>
        </select>

        <button class="btn btn-primary w-full mt-2">
          Update Task
        </button>

      </form>

      <a href="/tasks" class="btn btn-ghost btn-sm mt-2 text-center">
        ← Back to Tasks
      </a>

    </div>

  </div>

</div>

<%- include("partials/footer") %>