<link rel="stylesheet" href="/css/main.css" />
<%- include("partials/header", { title: "Tasks" }) %>

<div class="max-w-7xl mx-auto px-4 pt-10">

  <div class="flex items-center mb-8 gap-4">

    <a href="/dashboard" class="btn btn-ghost">
      ← Back
    </a>

    <h2 class="text-3xl font-bold">Your Tasks</h2>

    <a href="/tasks/add" class="btn btn-primary rounded-xl ml-auto">
      + Add Task
    </a>
  </div>

  <div class="overflow-x-auto">
    <table class="table table-zebra">
      <thead>
        <tr>
          <th>Title</th>
          <th>Description</th>
          <th>Due</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>

      <tbody>
      <% tasks.forEach(task => { %>
        <tr>
          <td><%= task.title %></td>
          <td><%= task.description %></td>
          <td><%= task.dueDate %></td>

          <td>
            <% if (task.status === "complete") { %>
              <span class="badge badge-success">Complete</span>
            <% } else { %>
              <span class="badge badge-warning">Pending</span>
            <% } %>
          </td>

          <td class="flex gap-2">
            <a class="btn btn-sm btn-info" href="/tasks/edit/<%= task.id %>">Edit</a>

            <form action="/tasks/delete/<%= task.id %>" method="POST">
              <button class="btn btn-sm btn-error">Delete</button>
            </form>

            <form action="/tasks/status/<%= task.id %>" method="POST">
              <button class="btn btn-sm">Toggle</button>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>

</div>

<%- include("partials/footer") %>